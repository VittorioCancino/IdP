# Hydra system secret — used to sign and encrypt internal tokens
# Generate with: openssl rand -hex 32
HYDRA_SYSTEM_SECRET=<your-hydra-system-secret>

# PostgreSQL credentials for Hydra (used by compose.yml)
POSTGRES_DB=hydra
POSTGRES_USER=hydra
POSTGRES_PASSWORD=<your-db-password>

# Optional overrides (defaults shown)
# HYDRA_ISSUER_URL=http://127.0.0.1:4444/
# HYDRA_PUBLIC_PORT=4444
# HYDRA_ADMIN_PORT=4445
# POSTGRES_PORT=5432
# HYDRA_IMAGE=oryd/hydra:v25.4.0
