DATABASE_HOST=127.0.0.1
DATABASE_PORT=5433
DATABASE_USER=admin_web
DATABASE_PASSWORD=<your-db-password>
DATABASE_NAME=admin_web
DATABASE_URL=postgresql://admin_web:<your-db-password>@127.0.0.1:5433/admin_web?schema=public

# Generate with: openssl rand -hex 32
AUTH_SECRET=<your-auth-secret>
AUTH_URL=http://localhost:3000
HYDRA_ADMIN_URL=http://127.0.0.1:4445

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<your-admin-password>
ADMIN_NAME=Platform Admin

# ⚠️  DEV ONLY — REMOVE BEFORE PRODUCTION
# Set to true to skip session auth on API routes (never works in NODE_ENV=production)
DEV_BYPASS_AUTH=false
